#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
DEFAULT_TARGET_DIR="$CACHE_HOME/void-rs-target"
TARGET_DIR="${CARGO_TARGET_DIR:-$DEFAULT_TARGET_DIR}"
BIN_PATH="$TARGET_DIR/release/void"
NEEDS_BUILD=0
WATCH_PATHS=(
  "$ROOT_DIR/src"
  "$ROOT_DIR/Cargo.toml"
)

if [[ -f "$ROOT_DIR/Cargo.lock" ]]; then
  WATCH_PATHS+=("$ROOT_DIR/Cargo.lock")
fi

if [[ ! -x "$BIN_PATH" ]]; then
  NEEDS_BUILD=1
elif find "${WATCH_PATHS[@]}" -type f -newer "$BIN_PATH" | grep -q .; then
  NEEDS_BUILD=1
fi

if [[ "$NEEDS_BUILD" -eq 1 ]]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "Void binary is not built and cargo is not installed." >&2
    echo "Install Rust and run: cargo build --release" >&2
    exit 1
  fi
  mkdir -p "$TARGET_DIR"
  export CARGO_TARGET_DIR="$TARGET_DIR"
  echo "Building Void runtime (one-time)..." >&2
  cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" >/dev/null
  touch "$BIN_PATH" >/dev/null 2>&1 || true
fi

exec "$BIN_PATH" "$@"
