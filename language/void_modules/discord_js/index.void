module.exports.name = "discord.js"
module.exports.version = "14.25.1"
module.exports.kind = "npm_bridge"
module.exports.entry_js = "npm/package/./src/index.js"

module.exports.run_entry = fn () {
use "cmd" as cmd
return cmd.run("node '" + __dirname + "/" + module.exports.entry_js + "'")
}

module.exports.run = fn (relative_js) {
use "cmd" as cmd
return cmd.run("node '" + __dirname + "/npm/package/" + relative_js + "'")
}
