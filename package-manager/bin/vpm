#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_PATH="$ROOT_DIR/target/release/vpm"
NEEDS_BUILD=0

if [[ ! -x "$BIN_PATH" ]]; then
  NEEDS_BUILD=1
elif find \
  "$ROOT_DIR/vpm/src" \
  "$ROOT_DIR/vpm/Cargo.toml" \
  "$ROOT_DIR/Cargo.toml" \
  "$ROOT_DIR/Cargo.lock" \
  -type f -newer "$BIN_PATH" | grep -q .; then
  NEEDS_BUILD=1
fi

if [[ "$NEEDS_BUILD" -eq 1 ]]; then
  source "$HOME/.cargo/env"
  cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" -p vpm >/dev/null
fi

exec "$BIN_PATH" "$@"
