#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${VOID_BUILD_PROFILE:-dev}"
case "$PROFILE" in
  dev|release) ;;
  *)
    echo "Invalid VOID_BUILD_PROFILE '$PROFILE' (expected: dev or release)" >&2
    exit 2
    ;;
esac

TARGET_DIR="debug"
if [[ "$PROFILE" == "release" ]]; then
  TARGET_DIR="release"
fi

BIN_PATH="$ROOT_DIR/target/$TARGET_DIR/vpm"
NEEDS_BUILD=0

if [[ ! -x "$BIN_PATH" ]]; then
  NEEDS_BUILD=1
elif find \
  "$ROOT_DIR/vpm/src" \
  "$ROOT_DIR/vpm/Cargo.toml" \
  "$ROOT_DIR/Cargo.toml" \
  "$ROOT_DIR/Cargo.lock" \
  -type f -newer "$BIN_PATH" | grep -q .; then
  NEEDS_BUILD=1
fi

if [[ "$NEEDS_BUILD" -eq 1 ]]; then
  source "$HOME/.cargo/env"
  echo "[vpm] building ($PROFILE)..." >&2
  if [[ "$PROFILE" == "release" ]]; then
    cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" -p vpm >/dev/null
  else
    cargo build --manifest-path "$ROOT_DIR/Cargo.toml" -p vpm >/dev/null
  fi
fi

exec "$BIN_PATH" "$@"
