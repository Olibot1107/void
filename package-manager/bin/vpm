#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ ! -f "$ROOT_DIR/Cargo.toml" ]]; then
  echo "[vpm] could not locate package-manager root at: $ROOT_DIR" >&2
  echo "Expected Cargo.toml at $ROOT_DIR/Cargo.toml" >&2
  exit 1
fi

# Explicit server mode: `vpm server ...` launches the registry.
if [[ "${1:-}" == "server" ]]; then
  shift
  exec "$ROOT_DIR/bin/void-registry" "$@"
fi

PROFILE="${VOID_BUILD_PROFILE:-dev}"
case "$PROFILE" in
  dev|release) ;;
  *)
    echo "Invalid VOID_BUILD_PROFILE '$PROFILE' (expected: dev or release)" >&2
    exit 2
    ;;
esac

TARGET_DIR="debug"
if [[ "$PROFILE" == "release" ]]; then
  TARGET_DIR="release"
fi

BIN_PATH="$ROOT_DIR/target/$TARGET_DIR/vpm"
NEEDS_BUILD=0

if [[ ! -x "$BIN_PATH" ]]; then
  NEEDS_BUILD=1
elif find \
  "$ROOT_DIR/vpm/src" \
  "$ROOT_DIR/vpm/Cargo.toml" \
  "$ROOT_DIR/Cargo.toml" \
  "$ROOT_DIR/Cargo.lock" \
  -type f -newer "$BIN_PATH" | grep -q .; then
  NEEDS_BUILD=1
fi

if [[ "$NEEDS_BUILD" -eq 1 ]]; then
  if [[ -f "$HOME/.cargo/env" ]]; then
    # shellcheck disable=SC1090
    source "$HOME/.cargo/env"
  fi
  if ! command -v cargo >/dev/null 2>&1; then
    echo "[vpm] cargo not found in PATH and $HOME/.cargo/env is missing." >&2
    echo "Install Rust with rustup or add cargo to PATH: https://rustup.rs" >&2
    exit 1
  fi
  echo "[vpm] building ($PROFILE)..." >&2
  if [[ "$PROFILE" == "release" ]]; then
    cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" -p vpm >/dev/null
  else
    cargo build --manifest-path "$ROOT_DIR/Cargo.toml" -p vpm >/dev/null
  fi
fi

exec "$BIN_PATH" "$@"
