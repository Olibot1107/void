#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${VOID_BUILD_PROFILE:-dev}"
case "$PROFILE" in
  dev|release) ;;
  *)
    echo "Invalid VOID_BUILD_PROFILE '$PROFILE' (expected: dev or release)" >&2
    exit 2
    ;;
esac

TARGET_DIR="debug"
if [[ "$PROFILE" == "release" ]]; then
  TARGET_DIR="release"
fi

BIN_PATH="$ROOT_DIR/target/$TARGET_DIR/void-registry"
NEEDS_BUILD=0

if [[ ! -x "$BIN_PATH" ]]; then
  NEEDS_BUILD=1
elif find \
  "$ROOT_DIR/registry/src" \
  "$ROOT_DIR/registry/templates" \
  "$ROOT_DIR/registry/Cargo.toml" \
  "$ROOT_DIR/Cargo.toml" \
  "$ROOT_DIR/Cargo.lock" \
  -type f -newer "$BIN_PATH" | grep -q .; then
  NEEDS_BUILD=1
fi

if [[ "$NEEDS_BUILD" -eq 1 ]]; then
  if [[ -f "$HOME/.cargo/env" ]]; then
    # shellcheck disable=SC1090
    source "$HOME/.cargo/env"
  fi
  if ! command -v cargo >/dev/null 2>&1; then
    echo "[void-registry] cargo not found in PATH and $HOME/.cargo/env is missing." >&2
    echo "Install Rust with rustup or add cargo to PATH: https://rustup.rs" >&2
    exit 1
  fi
  echo "[void-registry] building ($PROFILE)..." >&2
  if [[ "$PROFILE" == "release" ]]; then
    cargo build --release --manifest-path "$ROOT_DIR/Cargo.toml" -p void-registry >/dev/null
  else
    cargo build --manifest-path "$ROOT_DIR/Cargo.toml" -p void-registry >/dev/null
  fi
fi

export VOID_REGISTRY_DB="${VOID_REGISTRY_DB:-$ROOT_DIR/registry.db}"
exec "$BIN_PATH" "$@"
